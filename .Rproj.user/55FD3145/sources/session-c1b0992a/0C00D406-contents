```

### 9.4 What is the `AvePM` estimate (95% CI) in the **southeast** region?  

```{r}
region <- "southeast"

coef.mat <- summary(mod.interaction)$coefficients
var.mat  <- vcov(mod.interaction)

term.int <- paste0("AvePM:ClimateRegion", region)

# Region-specific slope for AvePM
beta <- coef.mat["AvePM", "Estimate"] +
  if (term.int %in% rownames(coef.mat)) coef.mat[term.int, "Estimate"] else 0

# Variance of the region-specific slope (delta method)
var.beta <- var.mat["AvePM", "AvePM"] +
  if (term.int %in% rownames(var.mat)) var.mat[term.int, term.int] else 0 +
  2 * if (term.int %in% rownames(var.mat)) var.mat["AvePM", term.int] else 0

se  <- sqrt(abs(var.beta))
lci <- beta - 1.96 * se
uci <- beta + 1.96 * se

tibble::tibble(
  region   = region,
  estimate = round(beta, 4),
  conf.low = round(lci, 4),
  conf.high= round(uci, 4)
)
```

### 9.5 Challenge: Does the PM2.5–BMI association differ for counties above vs below the median `MaleUnemp`?

```{r}
MedianMaleUnemp <- median(dta$MaleUnemp, na.rm = TRUE)

dta <- dta |>
  dplyr::mutate(
    MaleUnempAboveMedian = dplyr::if_else(
      MaleUnemp > MedianMaleUnemp,
      "Above median",
      "Below median"
    ),
    MaleUnempAboveMedian = factor(MaleUnempAboveMedian, levels = c("Below median", "Above median"))
  )

# Model without interaction (but with the group main effect)
mod.male.grp <- lm(
  AveBMI ~ AvePM + MaleUnempAboveMedian +
    PerBlack + PerLatinx + PerAsianAm +
    MedHInc + MedHVal + LTHS + FemaleUnemp + ClimateRegion,
  data = dta
)

# Model with interaction
mod.male.int <- lm(
  AveBMI ~ AvePM * MaleUnempAboveMedian +
    PerBlack + PerLatinx + PerAsianAm +
    MedHInc + MedHVal + LTHS + FemaleUnemp + ClimateRegion,
  data = dta
)

# LRT for interaction
anova(mod.male.grp, mod.male.int, test = "LRT")
```

```{r}
# Extract stratum-specific slopes for AvePM
b <- coef(mod.male.int)
V <- vcov(mod.male.int)

beta_below <- b["AvePM"]
se_below   <- sqrt(V["AvePM", "AvePM"])

term_int <- "AvePM:MaleUnempAboveMedianAbove median"
beta_above <- beta_below + if (term_int %in% names(b)) b[term_int] else 0

var_above <- V["AvePM", "AvePM"] +
  if (term_int %in% rownames(V)) V[term_int, term_int] else 0 +
  2 * if (term_int %in% rownames(V)) V["AvePM", term_int] else 0

se_above <- sqrt(abs(var_above))

tibble::tibble(
  stratum  = c("Below median MaleUnemp", "Above median MaleUnemp"),
  estimate = round(c(beta_below, beta_above), 4),
  conf.low = round(c(beta_below - 1.96 * se_below, beta_above - 1.96 * se_above), 4),
  conf.high= round(c(beta_below + 1.96 * se_below, beta_above + 1.96 * se_above), 4)
)
```

