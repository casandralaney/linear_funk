### 12.3 **Sensitivity to extreme values**  

Refit the main model after excluding counties in the top 1% of `AvePM`. How does the estimate change?

```{r}
cut99 <- quantile(dta$AvePM, probs = 0.99, na.rm = TRUE)

dta.no_top1 <- dta |>
  dplyr::filter(AvePM <= cut99)

mod.no_top1 <- lm(
  AveBMI ~ AvePM + PerBlack + PerLatinx + PerAsianAm +
    MedHInc + MedHVal + LTHS + FemaleUnemp + MaleUnemp + ClimateRegion,
  data = dta.no_top1
)

pm_main <- broom::tidy(mod, conf.int = TRUE) |>
  dplyr::filter(term == "AvePM") |>
  dplyr::mutate(model = "Main model (all counties)")

pm_sens <- broom::tidy(mod.no_top1, conf.int = TRUE) |>
  dplyr::filter(term == "AvePM") |>
  dplyr::mutate(model = "Exclude top 1% AvePM")

dplyr::bind_rows(pm_main, pm_sens) |>
  dplyr::transmute(
    model,
    estimate  = round(estimate, 4),
    conf.low  = round(conf.low, 4),
    conf.high = round(conf.high, 4)
  )
```

